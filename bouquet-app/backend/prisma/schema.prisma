// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  passwordHash           String?
  googleSub              String?        @unique
  name                   String
  isVerified             Boolean        @default(false)
  verificationToken      String?        @unique
  tokenExpiresAt         DateTime?
  resetPasswordToken     String?
  resetPasswordExpiresAt DateTime?
  phone                  String?
  address                Address?
  orders                 Order[]
  wishlist               WishlistItem[]
  cartItems              CartItems[]
  role                   Role           @relation(fields: [roleId], references: [id])
  roleId                 String
}

model WishlistItem {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  title      String   @default("Custom Bouquet")
  bouquet    Json
  totalPrice Float
  createdAt  DateTime @default(now())
}

model Role {
  id    String @id @default(uuid())
  name  String @unique
  users User[]
}

model Address {
  id      String  @id @default(uuid())
  user    User    @relation(fields: [userId], references: [id])
  userId  String  @unique
  street  String
  city    String
  state   String
  zipCode String
  details String?
}

model Order {
  id                   String         @id @default(uuid())
  user                 User?          @relation(fields: [userId], references: [id])
  userId               String?
  guestSessionId       String?
  customerEmail        String?
  customerName         String
  customerPhone        String
  deliveryStreet       String
  deliveryCity         String
  deliveryState        String
  deliveryZipCode      String
  deliveryDetails      String?
  deliveryOption       DeliveryOption
  scheduledFor         DateTime?
  scheduledSlot        String?
  paymentMethod        PaymentMethod
  promoCode            String?
  promoDiscountPercent Float?
  lines                LineOrder[]
  totalPrice           Float
  totalDiscount        Float
  deliveryTax          Float
  finalPrice           Float
  status               OrderStatus
  createdAt            DateTime       @default(now())

  @@index([guestSessionId])
  @@index([customerEmail])
}

model LineOrder {
  id                   String  @id @default(uuid())
  order                Order   @relation(fields: [orderId], references: [id])
  orderId              String
  bouquet              Bouquet @relation(fields: [bouquetId], references: [id])
  bouquetId            String
  quantity             Int
  priceBouquetSnapshot Float
  totalPrice           Float
}

model Bouquet {
  id        String        @id @default(uuid())
  price     Float
  items     ItemBouquet[] @relation("BouquetItems")
  lineOrder LineOrder[]
  cartItems CartItems[]
}

model CartItems {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  sessionId String? // pentru utilizatorii neautentificati
  bouquet   Bouquet  @relation(fields: [bouquetId], references: [id], onDelete: Cascade)
  bouquetId String
  quantity  Int      @default(1)
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bouquetId])
  @@unique([sessionId, bouquetId])
  @@index([sessionId])
}

model ItemBouquet {
  id            String  @id @default(uuid())
  bouquet       Bouquet @relation("BouquetItems", fields: [bouquetId], references: [id])
  bouquetId     String
  product       Product @relation(fields: [productId], references: [id])
  productId     String
  quantity      Int
  priceSnapshot Float
}

enum ProductType {
  FLOWER
  WRAPPING
  ACCESSORY
}

enum DeliveryOption {
  STANDARD
  SAME_DAY
  EXPRESS
}

enum PaymentMethod {
  COD
  ONLINE
}

enum OrderStatus {
  CREATED
  CONFIRMED
  IN_PREPARATION
  READY_FOR_DELIVERY
  IN_DELIVERY
  DELIVERED
  FAILED
  CANCELLED
}

enum Color {
  PINK
  RED
  WHITE
  YELLOW
  PURPLE
  BROWN
  CLEAR
  GOLD
  SILVER
}

model Product {
  id           String        @id @default(uuid())
  name         String
  type         ProductType
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  stock        Int           @default(0)
  color        Color?
  imageUrl     String
  itemBouquets ItemBouquet[]
}

model PromoCode {
  id              String    @id @default(uuid())
  code            String    @unique
  discountPercent Float
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
