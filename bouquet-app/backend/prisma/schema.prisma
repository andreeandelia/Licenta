// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  name         String
  phone        String?
  address      Address?
  orders       Order[]
  wishlist     WishlistItem[]
  role         Role           @relation(fields: [roleId], references: [id])
  roleId       String
}

model WishlistItem {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  title      String   @default("Custom Bouquet")
  bouquet    Json
  totalPrice Float
  createdAt  DateTime @default(now())
}

model Role {
  id    String @id @default(uuid())
  name  String @unique
  users User[]
}

model Address {
  id      String  @id @default(uuid())
  user    User    @relation(fields: [userId], references: [id])
  userId  String  @unique
  street  String
  city    String
  state   String
  zipCode String
  details String?
}

model Order {
  id            String      @id @default(uuid())
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  lines         LineOrder[]
  totalPrice    Float
  totalDiscount Float
  deliveryTax   Float
  finalPrice    Float
  status        String
  createdAt     DateTime    @default(now())
}

model LineOrder {
  id                   String  @id @default(uuid())
  order                Order   @relation(fields: [orderId], references: [id])
  orderId              String
  bouquet              Bouquet @relation(fields: [bouquetId], references: [id])
  bouquetId            String
  quantity             Int
  priceBouquetSnapshot Float
  totalPrice           Float
}

model Bouquet {
  id        String        @id @default(uuid())
  price     Float
  items     ItemBouquet[] @relation("BouquetItems")
  lineOrder LineOrder[]
}

model ItemBouquet {
  id            String  @id @default(uuid())
  bouquet       Bouquet @relation("BouquetItems", fields: [bouquetId], references: [id])
  bouquetId     String
  product       Product @relation(fields: [productId], references: [id])
  productId     String
  quantity      Int
  priceSnapshot Float
}

enum ProductType {
  FLOWER
  WRAPPING
  ACCESSORY
}

enum Color {
  PINK
  RED
  WHITE
  YELLOW
  PURPLE
  BROWN
  CLEAR
  GOLD
  SILVER
}

model Product {
  id           String        @id @default(uuid())
  name         String
  type         ProductType
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  stock        Int           @default(0)
  color        Color?
  imageUrl     String
  itemBouquets ItemBouquet[]
}
